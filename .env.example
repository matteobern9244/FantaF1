MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<base-database>?retryWrites=true&w=majority&appName=Cluster0
ADMIN_SESSION_SECRET=<long-random-secret>
VITE_APP_LOCAL_NAME=<optional-local-hero-title>

# Optional local overrides
ASPNETCORE_ENVIRONMENT=Development
PORT=3001

# CI or isolated smoke only. Do not use for Render staging/production.
MONGODB_DB_NAME_OVERRIDE=
